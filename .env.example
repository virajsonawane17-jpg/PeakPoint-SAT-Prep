# PeakPoint server
PORT=5173
NODE_ENV=development

# Required to activate AI features. Keep this server-side only.
GEMINI_API_KEY=

# Optional override. Defaults to the stable Gemini Flash model.
GEMINI_MODEL=gemini-3.5-flash

# Supabase Auth verification for protected API routes.
# The publishable key is safe for server-side auth verification headers, but the service role key is not.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Optional admin protection for AI question generation.
# Comma-separated list, for example: admin@example.com,owner@example.com
ADMIN_EMAILS=

# Local-only convenience. Leave false in production.
ALLOW_DEMO_AUTH=false
